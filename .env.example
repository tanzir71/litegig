# Copy to .env and adjust for your host. Do not commit .env.
LITEGIG_DATA_DIR=./litegig_data
LITEGIG_DB_PATH=./litegig_data/litegig.db
LITEGIG_UPLOAD_DIR=../litegig_uploads
LITEGIG_LOG_PATH=./litegig_data/litegig_error.log

# Set this before enabling HTTP cron access.
LITEGIG_CRON_TOKEN=change-me-long-random-token

LITEGIG_SESSION_TIMEOUT_SEC=7200
LITEGIG_SESSION_ABSOLUTE_SEC=86400
LITEGIG_EXPORT_PII=false
LITEGIG_SECURITY_HEADERS=true

LITEGIG_MAX_UPLOAD_BYTES=5242880
LITEGIG_RATE_LOGIN_LIMIT=5
LITEGIG_RATE_LOGIN_WINDOW_SEC=900
LITEGIG_RATE_CRITICAL_LIMIT=60
LITEGIG_RATE_CRITICAL_WINDOW_SEC=3600
