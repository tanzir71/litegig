# Copy to .env and adjust for your host. Do not commit .env.
LITEGIG_DATA_DIR=./litegig_data
LITEGIG_DB_PATH=./litegig_data/litegig.db
LITEGIG_UPLOAD_DIR=../litegig_uploads
LITEGIG_BACKUP_DIR=./litegig_data/backups
LITEGIG_LOG_PATH=./litegig_data/litegig_error.log
LITEGIG_CURRENCY=USD
LITEGIG_LOCALE=en_US
LITEGIG_TIMEZONE=UTC

# Set this before enabling HTTP cron access.
LITEGIG_HTTP_CRON_ENABLED=false
LITEGIG_CRON_TOKEN=change-me-long-random-token

LITEGIG_SESSION_TIMEOUT_SEC=7200
LITEGIG_SESSION_ABSOLUTE_SEC=86400
LITEGIG_EXPORT_PII=false
LITEGIG_SECURITY_HEADERS=true
LITEGIG_SAMPLE_DATA_ENABLED=false

# Optional email notifications. Leave disabled to queue/log only.
LITEGIG_EMAIL_ENABLED=false
LITEGIG_EMAIL_FROM=no-reply@example.com
LITEGIG_EMAIL_REPLY_TO=support@example.com

# Optional SMS notifications. Use "log" for local/testing or "webhook" for a signed provider adapter.
LITEGIG_SMS_ENABLED=false
LITEGIG_SMS_DRIVER=log
LITEGIG_SMS_WEBHOOK_URL=
LITEGIG_SMS_WEBHOOK_SECRET=
LITEGIG_ALLOW_LOG_ONLY_NOTIFICATIONS=true

# Optional payment gateway adapter. Manual payment confirmation remains the default.
LITEGIG_PAYMENT_GATEWAY_ENABLED=false
LITEGIG_PAYMENT_GATEWAY_CHECKOUT_URL=
LITEGIG_PAYMENT_GATEWAY_WEBHOOK_SECRET=

# Optional error tracking webhook. Leave blank for local JSON error logs only.
LITEGIG_ERROR_WEBHOOK_URL=
LITEGIG_ERROR_WEBHOOK_SECRET=
LITEGIG_ALLOW_LOCAL_ERROR_LOGS=true
LITEGIG_NOTIFICATION_RETRY_LIMIT=3

LITEGIG_MAX_UPLOAD_BYTES=5242880
LITEGIG_RATE_LOGIN_LIMIT=5
LITEGIG_RATE_LOGIN_WINDOW_SEC=900
LITEGIG_RATE_CRITICAL_LIMIT=60
LITEGIG_RATE_CRITICAL_WINDOW_SEC=3600
